generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  passwordHash String
  role         String       @default("USER")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  auditLogs    AuditLog[]
  batches      Batch[]
  dpdAccounts  DpdAccount[]
  orders       Order[]
}

model DpdAccount {
  id             String    @id @default(cuid())
  userId         String
  accountName    String
  dpdUsername    String
  dpdPasswordEnc String
  loginUrl       String    @default("https://mydpd.dpd.de/login")
  sessionData    String?
  sessionExpiry  DateTime?
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id])
  orders         Order[]
}

model Order {
  id               String     @id @default(cuid())
  userId           String
  dpdAccountId     String
  customerOrderNo  String?
  trackingNumber   String?
  status           String     @default("PENDING")
  senderName       String
  senderCompany    String?
  senderPhone      String
  senderAddress    String
  senderCity       String
  senderZip        String
  senderCountry    String     @default("DE")
  recipientName    String
  recipientPhone   String
  recipientAddress String
  recipientCity    String
  recipientZip     String
  recipientCountry String
  weight           Float
  length           Float?
  width            Float?
  height           Float?
  productName      String?
  sku              String?
  quantity         Int        @default(1)
  declaredValue    Float?
  errorMessage     String?
  batchId          String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  batch            Batch?     @relation(fields: [batchId], references: [id])
  dpdAccount       DpdAccount @relation(fields: [dpdAccountId], references: [id])
  user             User       @relation(fields: [userId], references: [id])
}

model Batch {
  id           String   @id @default(cuid())
  userId       String
  fileName     String
  totalCount   Int
  successCount Int      @default(0)
  failCount    Int      @default(0)
  status       String   @default("PARSING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
  orders       Order[]
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  detail    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model License {
  id             String    @id @default(cuid())
  key            String    @unique
  isActive       Boolean   @default(true)
  expiresAt      DateTime?
  usageCount     Int       @default(0)
  lastUsedAt     DateTime?
  rateLimitCount Int       @default(0)
  windowStart    DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
